# verge configuration. Copy to verge.toml next to qzeroded.x64 and edit.
# Environment overrides: VERGE_OWNER, VERGE_PLUGINS, VERGE_DATABASE.

[server]
# SteamID64 of the server owner (gets permission level 5). MANDATORY.
owner = "76561198000000000"
# Plugins to load from the verge/plugins directory.
plugins = ["admin", "identity", "motd", "log", "balance", "fun"]
# Prefix for chat commands.
command_prefix = "!"
# SQLite database file (bans, permissions, mutes, clan tags, ...).
database = "verge.db"

[stats]
# Listen to QLDS's ZMQ stats feed (kill/death/round/game events).
# The server must run with: +set zmq_stats_enable 1
enabled = true
# Only needed if the server sets zmq_stats_password.
password = ""

[plugin.features]
# Extra Steam Workshop item ids forced onto connecting clients.
workshop = []
# Keep a race server running with fewer than 2 players.
solorace = false

[plugin.admin]
# Automatically pass votes when enough people voted yes (was qlx_votepass).
#vote_pass = true
#vote_pass_threshold = 0.33
#teamsize_minimum = 1
#teamsize_maximum = 8
# Ban players who leave too many games (was qlx_leaverBan).
#leaver_ban = false

[plugin.identity]
#enforce_steam_name = true

[plugin.motd]
#sound = "sound/vo/crash_new/37b_07_alt.wav"
#delay_ms = 2000

[plugin.balance]
#api_url = "http://qlstats.net/elo/"
#auto_balance = true
#use_local = true
#minimum_suggestion_diff = 25

[plugin.fun]
#sound_delay = 3

[plugin.log]
#dir = "chatlogs"
#max_logs = 3
#max_size = 3000000
